{
  "extends": "@solverse/typescript-config/base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": false,
    "module": "ESNext",
    "target": "ES6",
    "moduleResolution": "Node10",
    "outDir": "dist",
    "baseUrl": "src",
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
