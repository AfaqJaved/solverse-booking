{
  "name": "@solverse/jest-config",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" "
  },
  "main": "./dist/entry.js",
  "types": "./dist/entry.d.ts",
  "exports": {
    ".": {
      "import": "./dist/entry.js",
      "require": "./dist/entry.js",
      "types": "./dist/entry.d.ts"
    },
    "./base": {
      "import": "./dist/base.js",
      "require": "./dist/base.js",
      "types": "./dist/base.d.ts"
    },
    "./nest": {
      "import": "./dist/nest.js",
      "require": "./dist/nest.js",
      "types": "./dist/nest.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "require": "./dist/next.js",
      "types": "./dist/next.d.ts"
    }
  },
  "devDependencies": {
    "@jest/types": "^30.2.0",
    "jest": "^30.2.0",
    "next": "16.2.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.2"
  },
   "dependencies": {
    "@solverse/typescript-config": "workspace:*",
    "@solverse/eslint-config": "workspace:*"
  }
}
