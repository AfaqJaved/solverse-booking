		"@lucide/svelte": "^1.7.0",
		"@solverse/eslint-config": "workspace:*",
		"@solverse/typescript-config": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/axios": "^0.14.4",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
