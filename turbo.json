{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": ["PORT", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "db:generate": {
      "passThroughEnv": ["DATABASE_URL"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["DATABASE_URL"]
    },
    "db:migrate": {
      "passThroughEnv": ["DATABASE_URL"]
    }
  }
}
